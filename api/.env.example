# Telegram (required for your primary bot and for Telegram Login widget)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Public bot username (no @) for the Telegram Login button
TELEGRAM_BOT_USERNAME=UsernameWithoutAtSign

# Database (required; use Render PostgreSQL or any Postgres URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# AES-256 key for encrypting bot tokens and secrets (min 32 chars). Required if users save bot tokens via the site.
ENCRYPTION_KEY=your-32-character-secret-key-here!!

# Session signing (set a random string in production)
SESSION_SECRET=change-me-in-production

# Optional: LLM provider (e.g. Anthropic)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=

# Optional: reserved for future use (e.g. unlock codes for alternate bot modes)
# SYSTEM_UNLOCK_CODE=
# ADMIN_KEY=

# Node
NODE_ENV=development
PORT=3000
